# Polymarket Bot Configuration
# Copy this file to .env and fill in your API keys

# TheNewsAPI - Get yours at https://thenewsapi.com
VITE_THENEWS_API_KEY=your_thenewsapi_key_here

# GNews API - Get yours at https://gnews.io
VITE_GNEWS_API_KEY=your_gnews_api_key_here

# Trading Configuration (defaults shown)
VITE_START_CASH=1000
VITE_CONF_THRESHOLD=55
VITE_MAX_TRADE=40
VITE_PRICE_MIN=0.08
VITE_PRICE_MAX=0.92
VITE_MAX_OPEN=8
VITE_PRICE_REFRESH_MS=10000
VITE_SCAN_INTERVAL_MS=180000
